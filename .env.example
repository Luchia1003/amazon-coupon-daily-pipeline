# Amazon Seller Central
AMAZON_EMAIL=your_email@example.com
AMAZON_PASSWORD=your_password
AMAZON_SELLER_ID=AXXXXXXXXXX          # Seller Central URL 里的 merchant_id
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER  # 美国站默认值

# Amazon 二次验证（2FA）
# 在 Amazon 账号安全设置里把验证方式改为 Authenticator App
# 绑定时点"无法扫描？"获取文字 Secret Key，填在这里
AMAZON_TOTP_SECRET=

# Snowflake（RSA Key 认证）
SNOWFLAKE_USER=LUCHIACHANG
SNOWFLAKE_ACCOUNT=RRCWSFA-BSB89302
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SKU_PROFIT_PROJECT
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/luchia/rsa_private_key.pem
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=     # key 有密码保护才填
