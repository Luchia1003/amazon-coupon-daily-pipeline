# Amazon Seller Central
AMAZON_EMAIL=your_email@example.com
AMAZON_PASSWORD=your_password
AMAZON_SELLER_ID=AXXXXXXXXXX          # 见下方说明
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER  # 美国站默认值

# Amazon 二次验证（2FA）
# 推荐方案：在 Amazon 账号安全设置里把 SMS 改成 Authenticator App（Google/Microsoft）
# 切换时会显示一个二维码，点"无法扫描？"会出现文字 secret key，把那串字母复制到这里
AMAZON_TOTP_SECRET=                   # 例如 JBSWY3DPEHPK3PXP

# Snowflake（使用 RSA Key 认证，无需密码）
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/luchia/rsa_private_key.pem
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=     # 如果 key 有密码保护才填
